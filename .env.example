# Required: Your 0G network private key (with 0G tokens for inference payments)
OG_PRIVATE_KEY=0x_your_private_key_here

# Optional: Comma-separated API keys for clients (auto-generated if omitted)
# OG_API_KEYS=sk-0g-key1,sk-0g-key2

# Optional: Admin key for dashboard access (auto-generated if omitted)
# OG_ADMIN_KEY=my-secret-admin-key

# Optional: 0G RPC endpoint (defaults to mainnet)
# OG_RPC_URL=https://evmrpc.0g.ai

# Optional: Log directory for persistent JSONL logs
# OG_LOG_DIR=./logs

# Optional: Server port
# PORT=8000
